{
  "routes": [
    {
      "src": "/api/yt-proxy/(.*)",
      "dest": "/api/yt-proxy/[...path]?...path=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
